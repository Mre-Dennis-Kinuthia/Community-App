// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTH & USERS
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?   // hashed password (if using credentials)
  emailVerified DateTime?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  profile   MemberProfile?
  sessions  Session[]
  accounts  Account[]
  bookings  WorkspaceBooking[]
  notifications Notification[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// MEMBER PROFILES
// ============================================

model MemberProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio       String?   @db.Text
  skills    String[] // array of skills
  location  String?
  industry  String?
  role      String?
  experienceLevel String? // Early Career, Mid-Level, Senior, Expert
  availability String[] // Open to Collaboration, Seeking Mentorship, Offering Mentorship, etc.
  interests String[] // array of interests
  isFeatured Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("member_profiles")
}

// Connections between members (using User IDs directly)
model Connection {
  id        String   @id @default(cuid())
  fromUserId String
  toUserId   String
  status    String   @default("pending") // pending, accepted, blocked
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
  @@map("connections")
}

// Follow relationships (one-way, using User IDs)
model Follow {
  id        String   @id @default(cuid())
  followerId String
  followingId String
  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

// ============================================
// ADMIN & RBAC
// ============================================

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String   // hashed password
  role      String   // super_admin, content_manager, community_manager, programs_manager, finance_ops
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  newsPosts NewsPost[]

  @@map("admin_users")
}

// ============================================
// CONTENT
// ============================================

model NewsPost {
  id        String   @id @default(cuid())
  title     String
  slug      String?  @unique // URL-friendly slug (nullable for backward compatibility)
  content   String   @db.Text
  excerpt   String?
  imageUrl  String?
  status    String   @default("draft") // draft, scheduled, published
  publishedAt DateTime?
  
  // Featured and pinned
  isFeatured Boolean @default(false)
  isPinned   Boolean @default(false)
  featuredOrder Int? // Order for featured posts carousel
  
  // Analytics
  viewCount Int      @default(0)
  readingTimeMinutes Int? // Cached reading time
  
  // Relations
  authorId  String?
  author    AdminUser? @relation(fields: [authorId], references: [id])
  categoryId String?
  category  Category?  @relation(fields: [categoryId], references: [id])
  tags      NewsPostTag[]
  comments  NewsPostComment[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // soft delete

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([isFeatured, publishedAt])
  @@index([isPinned, publishedAt])
  @@index([slug])
  @@map("news_posts")
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  startDate   DateTime
  endDate     DateTime?
  location    String?
  imageUrl    String?
  capacity    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  registrations EventRegistration[]

  @@map("events")
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String?  // nullable for guest registrations
  email     String
  name      String?
  status    String   @default("registered") // registered, cancelled, attended
  createdAt DateTime @default(now())

  @@map("event_registrations")
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  url         String?
  fileUrl     String?
  type        String   // link, file, video, etc.
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@map("resources")
}

// ============================================
// PLACEHOLDER MODELS (to be expanded)
// ============================================

model Project {
  id        String   @id @default(cuid())
  title     String
  description String? @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@map("projects")
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String?
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@map("partners")
}

// ============================================
// WORKSPACE BOOKINGS
// ============================================

model WorkspaceBooking {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Booking details
  resourceType  String   // hot-desk, meeting-room, private-office
  date          DateTime
  startTime     String   // e.g., "09:00"
  duration      String   // hourly, half-day, full-day
  endTime       String?  // calculated end time
  
  // Pricing
  basePrice     Float
  addOnsPrice   Float    @default(0)
  totalPrice    Float
  
  // Add-ons (stored as JSON array of add-on IDs)
  addOns        String[] @default([])
  
  // Status
  status        String   @default("pending") // pending, confirmed, cancelled, completed
  paymentStatus String   @default("pending") // pending, paid, refunded
  
  // Additional info
  notes         String?  @db.Text
  workspaceId   String   @default("impact-hub-nairobi")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  cancelledAt   DateTime?

  @@map("workspace_bookings")
  @@index([userId])
  @@index([date])
  @@index([status])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String   @id @default(cuid())
  userId    String?  // null for broadcast notifications
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Notification content
  title     String
  message   String   @db.Text
  type      String   @default("info") // info, success, warning, error
  category  String?  // booking, event, news, system, etc.
  
  // Metadata
  read      Boolean  @default(false)
  readAt    DateTime?
  actionUrl String?  // URL to navigate to when clicked
  
  // Related entity (optional)
  relatedId String?  // ID of related entity (booking, event, etc.)
  relatedType String? // Type of related entity
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // soft delete
  
  @@map("notifications")
  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([category])
}

// ============================================
// NEWS CATEGORIES & TAGS
// ============================================

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  color       String?  // For UI categorization (e.g., "#3b82f6")
  posts       NewsPost[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("categories")
}

model NewsTag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  posts     NewsPostTag[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("news_tags")
}

model NewsPostTag {
  postId  String
  tagId   String
  post    NewsPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag     NewsTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@unique([postId, tagId])
  @@map("news_post_tags")
}

// ============================================
// NEWS COMMENTS
// ============================================

model NewsPostComment {
  id        String   @id @default(cuid())
  postId    String
  post      NewsPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  // Author can be admin or member (optional for guest comments)
  authorId  String?  // AdminUser ID or User ID
  authorName String  // Display name
  authorEmail String? // Email (for notifications)
  
  content   String   @db.Text
  approved  Boolean  @default(true) // Auto-approve for now, can add moderation later
  
  // Nested comments support
  parentId  String?
  parent    NewsPostComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   NewsPostComment[] @relation("CommentReplies")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // soft delete
  
  @@index([postId])
  @@index([parentId])
  @@index([approved])
  @@map("news_post_comments")
}
