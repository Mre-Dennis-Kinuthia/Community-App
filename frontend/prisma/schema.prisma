// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// INVESTMENT & DEALFLOW ENUMS
// ============================================

enum InvestmentVisibility {
  public
  investors_only
  request_access
}

enum MediaAssetAccessLevel {
  public
  investors_only
  request_access
}

enum MediaAssetFileType {
  pitch_deck
  financial_model
  cap_table
  incorporation
  impact_metrics
  contracts
  other
}

enum InvestmentInterestStatus {
  requested
  approved
  declined
}

enum FundingStage {
  pre_seed
  seed
  series_a
  series_b
  other
}

// ============================================
// AUTH & USERS
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?   // hashed password (if using credentials)
  emailVerified DateTime?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  profile   MemberProfile?
  sessions  Session[]
  accounts  Account[]
  bookings  WorkspaceBooking[]
  notifications Notification[]
  subscriptions Subscription[]
  membershipPaymentLinks MembershipPaymentLink[]
  payments  Payment[]
  paymentMethods PaymentMethod[]
  invoices  Invoice[]
  projects  Project[]           // projects founded
  projectFollows ProjectFollow[]
  projectVolunteers ProjectVolunteer[]
  projectCollaborations ProjectCollaboration[]
  investmentInterests ProjectInvestmentInterest[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// MEMBER PROFILES
// ============================================

model MemberProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio       String?   @db.Text
  skills    String[] // array of skills
  location  String?
  industry  String?
  role      String?
  experienceLevel String? // Early Career, Mid-Level, Senior, Expert
  availability String[] // Open to Collaboration, Seeking Mentorship, Offering Mentorship, etc.
  interests String[] // array of interests
  isFeatured Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Investor metadata
  // Note: production DB may not yet have this column.
  // Keep it optional so Prisma doesn't fail queries/creates.
  isInvestor  Boolean?
  investorType String?
  ticketSizeMin Float?
  ticketSizeMax Float?
  sectorFocus   Json?
  stageFocus    Json?
  geoFocus      Json?
  thesis        String?
  investmentAlertPreferences Json?

  @@map("member_profiles")
}

// Connections between members (using User IDs directly)
model Connection {
  id        String   @id @default(cuid())
  fromUserId String
  toUserId   String
  status    String   @default("pending") // pending, accepted, blocked
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
  @@map("connections")
}

// Follow relationships (one-way, using User IDs)
model Follow {
  id        String   @id @default(cuid())
  followerId String
  followingId String
  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

// ============================================
// ADMIN & RBAC
// ============================================

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String   // hashed password
  role      String   // super_admin, content_manager, community_manager, programs_manager, finance_ops
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  newsPosts NewsPost[]

  @@map("admin_users")
}

// ============================================
// CONTENT
// ============================================

model NewsPost {
  id        String   @id @default(cuid())
  title     String
  slug      String?  @unique // URL-friendly slug (nullable for backward compatibility)
  content   String   @db.Text
  excerpt   String?
  imageUrl  String?
  status    String   @default("draft") // draft, scheduled, published
  publishedAt DateTime?
  
  // Featured and pinned
  isFeatured Boolean @default(false)
  isPinned   Boolean @default(false)
  featuredOrder Int? // Order for featured posts carousel
  
  // Analytics
  viewCount Int      @default(0)
  readingTimeMinutes Int? // Cached reading time
  
  // Relations
  authorId  String?
  author    AdminUser? @relation(fields: [authorId], references: [id])
  categoryId String?
  category  Category?  @relation(fields: [categoryId], references: [id])
  tags      NewsPostTag[]
  comments  NewsPostComment[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // soft delete

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([isFeatured, publishedAt])
  @@index([isPinned, publishedAt])
  @@index([slug])
  @@map("news_posts")
}

model Event {
  id                   String   @id @default(cuid())
  title                String
  slug                 String?  @unique
  shortCode            String?  @unique
  description          String   @db.Text
  startDate            DateTime
  endDate              DateTime?
  location             String?
  locationType         String   @default("in-person") // in-person, online, hybrid
  onlineUrl            String?
  imageUrl             String?
  capacity             Int?
  eventType            String   @default("other") // workshop, meetup, conference, etc.
  timezone             String   @default("Africa/Nairobi")
  visibility           String   @default("public") // public, private, members
  waitlistEnabled              Boolean  @default(false)
  registrationRequired         Boolean  @default(true)
  registrationRequiresApproval Boolean  @default(false)
  organizerName        String?
  organizerEmail       String?
  tags                 String[]
  price                Float?
  currency             String   @default("KES")
  registrationQuestions Json?
  reminderHoursBefore  Int?
  reminderSentAt       DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  deletedAt            DateTime?

  registrations   EventRegistration[]
  communications  EventCommunication[]

  @@index([startDate])
  @@index([eventType])
  @@index([visibility])
  @@index([slug])
  @@index([shortCode])
  @@map("events")
}

model EventRegistration {
  id            String   @id @default(cuid())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId        String?  // nullable for guest registrations
  email         String
  name          String?
  status        String   @default("registered") // registered, waitlisted, pending, rejected, cancelled, attended
  checkInCode   String?  @unique
  answers       Json?
  paymentStatus String   @default("not_required") // not_required, pending, paid
  createdAt     DateTime @default(now())

  @@map("event_registrations")
}

model EventCommunication {
  id             String   @id @default(cuid())
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title          String
  message        String   @db.Text
  audience       String   // registered, waitlisted, all_active, attended
  recipientCount Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([eventId])
  @@map("event_communications")
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  url         String?
  fileUrl     String?
  type        String   // link, file, video, etc.
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@map("resources")
}

// ============================================
// PLACEHOLDER MODELS (to be expanded)
// ============================================

model Project {
  id          String    @id @default(cuid())
  title       String
  description String    @db.Text
  category    String?   // Climate & Environment, Agriculture, etc.
  stage       String?   // Early Stage, Growth, Scaling
  impact      String?   @db.Text
  imageUrl    String?   // Cover/thumbnail image URL for the project
  metrics     Json?     // Object with metrics
  tags        String[]  @default([])
  founderId   String?   // optional for backward compatibility
  founder     User?     @relation(fields: [founderId], references: [id], onDelete: SetNull)
  location    String?
  needs       String[]  @default([]) // Seeking Funding, Seeking Collaborators, etc.
  website     String?
  socialLinks Json?     // Object with social links
  launchDate  DateTime?
  isFeatured  Boolean   @default(false)
  // Investment & funding fields
  isInvestmentOpen    Boolean              @default(false)
  investmentApproved  Boolean              @default(false)
  investmentVisibility InvestmentVisibility @default(investors_only)
  capitalSought       Float?
  ticketMin           Float?
  ticketMax           Float?
  revenueMonthly      Float?
  growthRateMonthly   Float?
  runwayMonths        Int?
  lastRoundAmount     Float?
  lastRoundDate       DateTime?
  fundingStage        FundingStage?
  readinessScore      Int?
  // Publish workflow: pending = awaiting admin approval, approved = visible on community, rejected = not published
  status      String    @default("approved") // "draft" | "pending" | "approved" | "rejected"
  submittedAt DateTime?
  approvedAt  DateTime?
  approvedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  followers             ProjectFollow[]
  volunteers            ProjectVolunteer[]
  collaborationRequests  ProjectCollaboration[]
  investmentInterests   ProjectInvestmentInterest[]
  mediaAssets           MediaAsset[]

  @@map("projects")
  @@index([founderId])
  @@index([category])
  @@index([stage])
  @@index([isFeatured])
  @@index([status])
}

model ProjectFollow {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@map("project_follows")
  @@index([userId])
}

model ProjectVolunteer {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("pending") // pending, accepted, rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId])
  @@map("project_volunteers")
  @@index([userId])
}

model ProjectCollaboration {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String?  @db.Text
  status    String   @default("pending") // pending, accepted, rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId])
  @@map("project_collaborations")
  @@index([userId])
}

model Partner {
  id              String   @id @default(cuid())
  name            String
  type            String?  // Workspace Partner, Investor, Partner, Funder, Government, Network
  category        String?  // Infrastructure, Funding, Ecosystem, Public Sector
  description     String?  @db.Text
  logoUrl         String?
  website         String?
  location        String?
  locationType    String?  // Local, Global
  focus           String[] @default([]) // Array of focus areas
  contactEmail    String?
  isFeatured      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  opportunities   PartnerOpportunity[]

  @@map("partners")
  @@index([type])
  @@index([category])
  @@index([locationType])
}

model PartnerOpportunity {
  id                  String   @id @default(cuid())
  partnerId           String
  partner             Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  title               String
  description         String   @db.Text
  category            String?  // Funding, Program, Resource
  amount              String?  // e.g., "$50K - $2M"
  deadline            DateTime?
  eligibility         String[] @default([])
  applicationProcess  String[] @default([]) // process steps
  status              String   @default("Open") // Open, Closed, Ongoing
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?

  @@map("partner_opportunities")
  @@index([partnerId])
  @@index([status])
}

// ============================================
// WORKSPACE BOOKINGS
// ============================================

model WorkspaceBooking {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Booking details
  resourceType  String   // hot-desk, meeting-room, private-office
  date          DateTime
  startTime     String   // e.g., "09:00"
  duration      String   // hourly, half-day, full-day
  endTime       String?  // calculated end time
  
  // Pricing
  basePrice     Float
  addOnsPrice   Float    @default(0)
  totalPrice    Float
  
  // Add-ons (stored as JSON array of add-on IDs)
  addOns        String[] @default([])
  
  // Status
  status        String   @default("pending") // pending, confirmed, cancelled, completed
  paymentStatus String   @default("pending") // pending, paid, refunded
  
  // Additional info
  notes         String?  @db.Text
  workspaceId   String   @default("impact-hub-nairobi")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  cancelledAt   DateTime?

  @@map("workspace_bookings")
  @@index([userId])
  @@index([date])
  @@index([status])
}

// ============================================
// WORKSPACES (LISTINGS)
// ============================================

model Workspace {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  location          String?
  address           String?
  valueProposition  String?  @db.Text
  startingPrice     Int?
  currency          String   @default("KES")
  images            String[] @default([])
  // Extended configuration used by the member booking experience
  amenities         Json?
  whoIsThisFor      String?  @db.Text
  openingHours      String?  @db.Text
  houseRules        String[] @default([])
  securityInfo      String?  @db.Text
  coordinates       Json?
  landmarks         String[] @default([])
  companyLogos      String[] @default([])
  pricing           Json?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  @@map("workspaces")
  @@index([isActive])
}

// ============================================
// BILLING & SUBSCRIPTIONS
// ============================================

model Plan {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  price       Decimal  @db.Decimal(12, 2)
  currency    String   @default("KES")
  interval    String   // monthly, yearly
  features    Json?    // Array of feature strings
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
  membershipPaymentLinks MembershipPaymentLink[]

  @@map("plans")
}

/// Admin-issued checkout link for monthly membership (members or prospects).
model MembershipPaymentLink {
  id               String    @id @default(cuid())
  token            String    @unique
  planId           String
  plan             Plan      @relation(fields: [planId], references: [id])
  recipientEmail   String
  recipientName    String?
  userId           String?
  user             User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  amount           Decimal   @db.Decimal(12, 2)
  currency         String    @default("KES")
  status           String    @default("pending") // pending, paid, expired, cancelled
  expiresAt        DateTime
  paidAt           DateTime?
  paymentId        String?   @unique
  payment          Payment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  subscriptionId   String?
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  createdByAdminId String?
  adminNote        String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("membership_payment_links")
  @@index([status])
  @@index([recipientEmail])
  @@index([expiresAt])
}

model Subscription {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId              String
  plan                Plan     @relation(fields: [planId], references: [id])
  status              String   // active, cancelled, expired, trialing
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  cancelAtPeriodEnd   Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?

  payments Payment[]
  invoices Invoice[]
  membershipPaymentLinks MembershipPaymentLink[]

  @@map("subscriptions")
  @@index([userId])
  @@index([status])
}

model Payment {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  amount          Decimal   @db.Decimal(12, 2)
  currency        String    @default("KES")
  method          String    // mpesa, card, bank_transfer
  status          String    // pending, completed, failed, refunded
  transactionId   String?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  invoice Invoice?
  membershipPaymentLink MembershipPaymentLink?

  @@map("payments")
  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
}

model PaymentMethod {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // card, mpesa, bank_account
  provider    String?  // safaricom, stripe, etc.
  last4       String?
  brand       String?
  expiryMonth Int?
  expiryYear  Int?
  isDefault   Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@map("payment_methods")
  @@index([userId])
}

model Invoice {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  paymentId       String?   @unique
  payment         Payment?  @relation(fields: [paymentId], references: [id])
  invoiceNumber   String    @unique
  amount          Decimal   @db.Decimal(12, 2)
  currency        String    @default("KES")
  status          String    // draft, paid, overdue, cancelled
  dueDate         DateTime?
  paidAt          DateTime?
  pdfUrl          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("invoices")
  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String   @id @default(cuid())
  userId    String?  // null for broadcast notifications
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Notification content
  title     String
  message   String   @db.Text
  type      String   @default("info") // info, success, warning, error
  category  String?  // booking, event, news, system, etc.
  
  // Metadata
  read      Boolean  @default(false)
  readAt    DateTime?
  actionUrl String?  // URL to navigate to when clicked
  
  // Related entity (optional)
  relatedId String?  // ID of related entity (booking, event, etc.)
  relatedType String? // Type of related entity
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // soft delete
  
  @@map("notifications")
  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([category])
}

// ============================================
// PROGRAMS & COHORTS
// ============================================

model Program {
  id          String   @id @default(cuid())
  name        String
  type        String   // accelerator, incubator, fellowship, bootcamp
  description String?  @db.Text
  status      String   @default("upcoming") // upcoming, active, completed
  applicationOpen Boolean @default(false)
  capacity    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  cohorts     Cohort[]
  applications ProgramApplication[]

  @@map("programs")
}

model Cohort {
  id          String   @id @default(cuid())
  programId   String
  program     Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  name        String
  startDate   DateTime
  endDate     DateTime?
  phase       String?  // onboarding, active, graduation
  capacity    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  applications ProgramApplication[]

  @@map("cohorts")
}

// ============================================
// APPLICATIONS & SELECTION
// ============================================

model ProgramApplication {
  id          String   @id @default(cuid())
  programId   String
  program     Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  cohortId    String?
  cohort      Cohort?  @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  userId      String?
  applicantName String
  email       String
  venture     String?
  status      String   @default("in-review") // in-review, shortlisted, accepted, rejected, waitlist
  score       Int?     // evaluation score
  appliedDate DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("program_applications")
  @@index([programId])
  @@index([status])
}

// ============================================
// STORED IMAGES (binary in Postgres)
// ============================================

model StoredImage {
  id          String   @id @default(cuid())
  data        Bytes
  mimeType    String
  fileName    String?
  size        Int
  category    String   // profile, event_cover, news_cover, project_cover, partner_logo, general
  userId      String?
  adminUserId String?
  createdAt   DateTime @default(now())

  @@map("stored_images")
  @@index([category])
  @@index([userId])
  @@index([createdAt])
}

// ============================================
// MEDIA LIBRARY
// ============================================

model MediaAsset {
  id          String   @id @default(cuid())
  name        String
  type        String   // image, document, video, link
  url         String
  size        Int?     // file size in bytes
  mimeType    String?
  tags        String[]
  // Optional link to a project for diligence docs
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  accessLevel MediaAssetAccessLevel @default(public)
  fileType    MediaAssetFileType    @default(other)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@map("media_assets")
  @@index([type])
  @@index([projectId])
}

// ============================================
// INVESTMENT INTEREST
// ============================================

model ProjectInvestmentInterest {
  id         String   @id @default(cuid())
  projectId  String
  investorId String
  status     InvestmentInterestStatus @default(requested)
  message    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  investor User    @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@map("project_investment_interests")
  @@unique([projectId, investorId])
  @@index([projectId])
  @@index([investorId])
}

// ============================================
// AUDIT LOGS
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  actor     String   // admin email or system
  action    String   // create, update, delete, etc.
  target    String   // entity type and ID
  severity  String   @default("info") // info, warning, critical
  details   String?  @db.Text
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
  @@index([actor])
  @@index([action])
  @@index([createdAt])
  @@index([severity])
}

// ============================================
// SUPPORT & HELPDESK
// ============================================

model SupportTicket {
  id          String   @id @default(cuid())
  member      String   // member name or email
  subject     String
  description String   @db.Text
  status      String   @default("open") // open, pending, resolved, closed
  priority    String   @default("medium") // low, medium, high
  category    String?  // technical, billing, general
  assignedTo  String?  // admin email
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  resolvedAt DateTime?

  @@map("support_tickets")
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

// ============================================
// NEWS CATEGORIES & TAGS
// ============================================

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  color       String?  // For UI categorization (e.g., "#3b82f6")
  posts       NewsPost[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("categories")
}

model NewsTag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  posts     NewsPostTag[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("news_tags")
}

model NewsPostTag {
  postId  String
  tagId   String
  post    NewsPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag     NewsTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@unique([postId, tagId])
  @@map("news_post_tags")
}

// ============================================
// NEWS COMMENTS
// ============================================

model NewsPostComment {
  id        String   @id @default(cuid())
  postId    String
  post      NewsPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  // Author can be admin or member (optional for guest comments)
  authorId  String?  // AdminUser ID or User ID
  authorName String  // Display name
  authorEmail String? // Email (for notifications)
  
  content   String   @db.Text
  approved  Boolean  @default(true) // Auto-approve for now, can add moderation later
  
  // Nested comments support
  parentId  String?
  parent    NewsPostComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   NewsPostComment[] @relation("CommentReplies")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // soft delete
  
  @@index([postId])
  @@index([parentId])
  @@index([approved])
  @@map("news_post_comments")
}
